# Kudex Music - Environment Config

# Database
DATABASE_URL=postgresql+asyncpg://kudex:kudex_password@db:5432/kudex_db

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-super-secret-key-123456
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Traefik / SSL
DOMAIN=kudex.io
ACME_EMAIL=admin@kudex.io
